generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model users {
  id                    Int             @id @default(autoincrement())
  email                 String          @unique
  password              String
  name                  String
  surname               String
  created_at            DateTime        @default(now())
  access_token_yoomoney String?
  cookies               Json?           @db.Json
  email_ym              String?         @db.VarChar(255)
  password_ym           String?         @db.VarChar(255)
  subscriptions         subscriptions[]
}

model subscriptions {
  id          Int       @id @default(autoincrement())
  name        String    @db.VarChar(255)
  description String?
  start_date  DateTime  @db.Date
  end_date    DateTime  @db.Date
  price       Decimal   @db.Decimal(10, 2)
  flag_auto   Boolean?  @default(false)
  img         String?
  id_user     Int
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  updated_at  DateTime? @default(now()) @db.Timestamp(6)
  url         String?   @db.VarChar(255)
  users       users     @relation(fields: [id_user], references: [id], onDelete: Cascade, onUpdate: NoAction)
}
