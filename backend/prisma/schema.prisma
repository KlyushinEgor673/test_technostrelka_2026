generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model users {
  id                     Int                      @id @default(autoincrement())
  email                  String                   @unique
  password               String
  name                   String
  surname                String
  created_at             DateTime                 @default(now())
  access_token_yoomoney  String?
  cookies                Json?                    @db.Json
  email_ym               String?                  @db.VarChar(255)
  password_ym            String?                  @db.VarChar(255)
  is_enter_ym            Boolean?                 @default(false)
  debiting_subscriptions debiting_subscriptions[]
  subscriptions          subscriptions[]
}

model subscriptions {
  id          Int       @id @default(autoincrement())
  name        String    @db.VarChar(255)
  category_id Int?
  period      Int?
  end_date    DateTime? @db.Date
  price       Decimal?  @db.Decimal(10, 2)
  flag_auto   Boolean?
  img         Bytes?
  url         String?   @db.VarChar(500)
  id_user     Int?
  users       users?    @relation(fields: [id_user], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model debiting_subscriptions {
  date        DateTime @db.Date
  category_id Int
  user_id     Int
  price       Decimal  @db.Decimal(10, 2)
  category    category @relation(fields: [category_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users       users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([date, category_id, user_id])
}

model category {
  id                     Int                      @id @default(autoincrement())
  name                   String?                  @db.VarChar(255)
  color                  String?                  @db.VarChar(255)
  debiting_subscriptions debiting_subscriptions[]
}
